<!DOCTYPE html>
<html class="h-full bg-gray-50">
  <head>
    <title><%= content_for(:title) || "RoR出席管理システム" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="<%= asset_path('favicon.svg') %>" type="image/svg+xml">
    <link rel="apple-touch-icon" href="<%= asset_path('favicon.svg') %>">
    
    <!-- Google Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="h-full text-gray-900 antialiased font-sans overflow-x-hidden selection:bg-gray-900 selection:text-white">
    
    <% if current_user %>
      <!-- Desktop Sidebar -->
      <%= render "shared/sidebar_desktop" %>
      
      <!-- Mobile Bottom Nav -->
      <%= render "shared/mobile_nav" %>

      <!-- Main Content -->
      <main class="lg:pl-64 min-h-screen pb-20 lg:pb-8 transition-all duration-300">
        <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-6 lg:py-8">
          
          <!-- Flash Messages (Styled) -->
          <% if flash.any? %>
            <div class="mb-6 space-y-2">
              <% flash.each do |key, value| %>
                <% 
                  color_classes = case key.to_s
                    when "notice" then "bg-gray-900 text-white"
                    when "alert" then "bg-red-50 text-red-900 border border-red-100"
                    else "bg-gray-50 text-gray-900 border border-gray-100"
                  end
                %>
                <div class="<%= color_classes %> px-4 py-3 rounded-xl text-sm font-medium shadow-sm flex items-center justify-between animate-fade-in-down">
                  <span><%= value %></span>
                  <button type="button" onclick="this.parentElement.remove()" class="opacity-70 hover:opacity-100">
                    <%= lucide_icon("x", class: "w-4 h-4") %>
                  </button>
                </div>
              <% end %>
            </div>
          <% end %>

          <%= yield %>
        </div>
      </main>
    <% else %>
      <!-- Auth Layout (Login etc) -->
      <main class="min-h-screen flex flex-col justify-center py-12 sm:px-6 lg:px-8 bg-white">
        <%= yield %>
      </main>
    <% end %>

  </body>
</html>