<div class="min-h-screen bg-gray-50 flex flex-col justify-center py-12 sm:px-6 lg:px-8">
  <div class="sm:mx-auto sm:w-full sm:max-w-md">
    <div class="flex justify-center">
      <div class="w-16 h-16 rounded-2xl bg-gray-900 flex items-center justify-center shadow-sm">
        <span class="text-white text-2xl font-bold tracking-tighter">A</span>
      </div>
    </div>
    <h2 class="mt-6 text-center text-2xl font-bold tracking-tight text-gray-900">Attendance System</h2>
    <p class="mt-2 text-center text-sm text-gray-500">アカウントにログインしてください</p>
  </div>

  <div class="mt-8 sm:mx-auto sm:w-full sm:max-w-md">
    <div class="bg-white py-8 px-4 shadow-sm border border-gray-100 sm:rounded-[24px] sm:px-10" data-controller="login">
      <%= render "shared/flash" %>

      <%= form_with url: login_path, method: :post, class: "space-y-6" do |f| %>
        <%= hidden_field_tag :role, "student", data: { login_target: "roleInput" } %>
        
        <div>
          <%= f.label :email, "メールアドレス", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <div class="relative rounded-lg shadow-sm">
            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
              <%= lucide_icon "mail", class: "h-5 w-5 text-gray-400" %>
            </div>
            <%= f.email_field :email, class: "block w-full rounded-lg border-gray-200 pl-10 focus:border-gray-900 focus:ring-gray-900 sm:text-sm py-2.5 bg-gray-50/50", required: true, autofocus: true, autocomplete: "username", inputmode: "email", autocapitalize: "off", autocorrect: "off", spellcheck: "false", maxlength: 255, placeholder: "name@example.com", data: { login_target: "email" } %>
          </div>
        </div>

        <div>
          <%= f.label :password, "パスワード", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <div class="relative rounded-lg shadow-sm">
            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
              <%= lucide_icon "lock", class: "h-5 w-5 text-gray-400" %>
            </div>
            <%= f.password_field :password, class: "block w-full rounded-lg border-gray-200 pl-10 pr-10 focus:border-gray-900 focus:ring-gray-900 sm:text-sm py-2.5 bg-gray-50/50", required: true, autocomplete: "current-password", minlength: 8, maxlength: 72, autocapitalize: "off", autocorrect: "off", spellcheck: "false", data: { login_target: "password" } %>
            <button
              type="button"
              class="absolute inset-y-0 right-0 pr-3 flex items-center cursor-pointer"
              data-action="login#togglePassword"
            >
              <div data-login-target="eye">
                <%= lucide_icon "eye", class: "h-5 w-5 text-gray-400 hover:text-gray-600" %>
              </div>
              <div data-login-target="eyeOff" class="hidden">
                <%= lucide_icon "eye-off", class: "h-5 w-5 text-gray-400 hover:text-gray-600" %>
              </div>
            </button>
          </div>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">アカウントタイプ</label>
          <div class="grid grid-cols-2 gap-3">
            <button
              type="button"
              class="w-full py-2.5 px-4 border rounded-xl text-sm font-medium focus:outline-none transition-all duration-200"
              data-action="login#selectStudent"
              data-login-target="roleStudent"
              data-active-classes="bg-gray-900 border-gray-900 text-white shadow-sm"
              data-inactive-classes="bg-white border-gray-200 text-gray-600 hover:bg-gray-50 hover:text-gray-900"
            >
              学生
            </button>
            <button
              type="button"
              class="w-full py-2.5 px-4 border rounded-xl text-sm font-medium focus:outline-none transition-all duration-200"
              data-action="login#selectTeacher"
              data-login-target="roleTeacher"
              data-active-classes="bg-gray-900 border-gray-900 text-white shadow-sm"
              data-inactive-classes="bg-white border-gray-200 text-gray-600 hover:bg-gray-50 hover:text-gray-900"
            >
              教員
            </button>
          </div>
        </div>

        <div>
          <%= f.submit "ログイン", class: "w-full flex justify-center py-2.5 px-4 border border-transparent rounded-xl shadow-sm text-sm font-bold text-white bg-gray-900 hover:bg-gray-800 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-900 transition-colors" %>
        </div>
      <% end %>

      <div class="mt-8">
        <div class="relative">
          <div class="absolute inset-0 flex items-center">
            <div class="w-full border-t border-gray-100"></div>
          </div>
          <div class="relative flex justify-center text-sm">
            <span class="px-2 bg-white text-gray-400">Easy Login</span>
          </div>
        </div>

        <div class="mt-4 grid grid-cols-2 gap-3">
          <button
            type="button"
            class="w-full inline-flex justify-center items-center py-2 px-4 border border-gray-200 rounded-xl bg-white text-xs font-medium text-gray-600 hover:bg-gray-50 transition-colors"
            data-action="login#fillDemo"
            data-login-role-param="student"
          >
            学生デモ
          </button>
          <button
            type="button"
            class="w-full inline-flex justify-center items-center py-2 px-4 border border-gray-200 rounded-xl bg-white text-xs font-medium text-gray-600 hover:bg-gray-50 transition-colors"
            data-action="login#fillDemo"
            data-login-role-param="teacher"
          >
            教員デモ
          </button>
        </div>

        <div class="mt-8 flex justify-center space-x-4 text-xs text-gray-400">
          <%= link_to "利用規約", terms_path, class: "hover:text-gray-600 transition-colors" %>
          <span>•</span>
          <%= link_to "プライバシー", privacy_path, class: "hover:text-gray-600 transition-colors" %>
          <span>•</span>
          <%= link_to "データ保持", data_policy_path, class: "hover:text-gray-600 transition-colors" %>
        </div>
      </div>
    </div>
  </div>
</div>