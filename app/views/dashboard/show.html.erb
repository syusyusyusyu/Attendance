<% greeting = case Time.current.hour
  when 5..10
    "おはようございます"
  when 11..17
    "こんにちは"
  else
    "こんばんは"
  end %>

<% role_label = if @user.admin?
  "管理者"
elsif @user.teacher?
  "教員"
else
  "学生"
end %>

<div class="space-y-6 lg:space-y-0 lg:grid lg:grid-cols-12 lg:gap-6">
  
  <!-- Welcome Card (Full Width) -->
  <div class="lg:col-span-12 bg-white rounded-[24px] shadow-sm border border-gray-100 p-6 lg:p-8 flex items-center justify-between relative overflow-hidden">
    <div class="relative z-10">
      <h1 class="text-2xl lg:text-3xl font-bold text-gray-900 tracking-tight mb-2">
        <%= greeting %>、<%= @user.name %>さん
      </h1>
      <p class="text-gray-500 font-medium flex items-center gap-2">
        <span class="inline-flex items-center rounded-full bg-gray-100 px-2.5 py-0.5 text-xs font-medium text-gray-800">
          <%= role_label %>
        </span>
        ダッシュボード
      </p>
    </div>
    <!-- Decorator -->
    <div class="absolute right-0 top-0 w-64 h-64 bg-gradient-to-br from-gray-50 to-gray-100 rounded-full blur-3xl opacity-50 -mr-16 -mt-16 pointer-events-none"></div>
  </div>

  <% if @user.student? && @show_onboarding %>
    <!-- Onboarding (Full Width) -->
    <div class="lg:col-span-12 bg-white rounded-[24px] shadow-sm border border-blue-100 p-6 relative overflow-hidden">
      <div class="absolute top-0 right-0 p-4 opacity-10">
        <%= lucide_icon "info", class: "w-24 h-24 text-blue-600" %>
      </div>
      <h2 class="text-lg font-bold text-gray-900 mb-4 relative z-10">初回ガイド</h2>
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 relative z-10">
        <div class="space-y-2">
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-full bg-blue-50 text-blue-600 flex items-center justify-center font-bold text-sm">1</div>
            <p class="text-sm font-medium text-gray-700">QRをスキャンして出席</p>
          </div>
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-full bg-blue-50 text-blue-600 flex items-center justify-center font-bold text-sm">2</div>
            <p class="text-sm font-medium text-gray-700">退室時も同じQRをスキャン</p>
          </div>
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-full bg-blue-50 text-blue-600 flex items-center justify-center font-bold text-sm">3</div>
            <p class="text-sm font-medium text-gray-700">欠席/遅刻は申請フォームへ</p>
          </div>
        </div>
        
        <div class="bg-gray-50 rounded-xl p-4 border border-gray-100">
          <h3 class="text-sm font-bold text-gray-900 mb-2 flex items-center gap-2">
            <%= lucide_icon "help-circle", class: "w-4 h-4" %> FAQ
          </h3>
          <ul class="text-xs text-gray-600 space-y-1 list-disc list-inside">
            <li>カメラが起動しない場合は手入力を利用</li>
            <li>QRコードは1分ごとに更新されます</li>
          </ul>
        </div>

        <div class="bg-gray-50 rounded-xl p-4 border border-gray-100 flex flex-col justify-center text-center">
          <p class="text-xs text-gray-500 mb-1">操作動画を準備中</p>
          <p class="text-xs text-gray-400">Coming Soon</p>
        </div>
      </div>
    </div>
  <% end %>

  <!-- Quick Actions -->
  <% if @user.staff? %>
    <!-- Staff Actions -->
    <div class="lg:col-span-3">
      <%= link_to school_classes_path, class: "group block bg-white rounded-[24px] p-6 shadow-sm border border-gray-100 h-full hover:border-gray-200 hover:shadow-md transition-all duration-200" do %>
        <div class="w-12 h-12 rounded-2xl bg-blue-50 text-blue-600 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
          <%= lucide_icon "users", class: "w-6 h-6" %>
        </div>
        <h3 class="font-bold text-gray-900 mb-1">クラス管理</h3>
        <p class="text-xs text-gray-500">クラス作成・名簿管理</p>
      <% end %>
    </div>

    <div class="lg:col-span-3">
      <%= link_to attendance_path, class: "group block bg-white rounded-[24px] p-6 shadow-sm border border-gray-100 h-full hover:border-gray-200 hover:shadow-md transition-all duration-200" do %>
        <div class="w-12 h-12 rounded-2xl bg-green-50 text-green-600 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
          <%= lucide_icon "check-circle-2", class: "w-6 h-6" %>
        </div>
        <h3 class="font-bold text-gray-900 mb-1">出席確認</h3>
        <p class="text-xs text-gray-500">出席状況の確認・修正</p>
      <% end %>
    </div>

    <div class="lg:col-span-3">
      <%= link_to generate_qr_path, class: "group block bg-white rounded-[24px] p-6 shadow-sm border border-gray-100 h-full hover:border-gray-200 hover:shadow-md transition-all duration-200" do %>
        <div class="w-12 h-12 rounded-2xl bg-indigo-50 text-indigo-600 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
          <%= lucide_icon "qr-code", class: "w-6 h-6" %>
        </div>
        <h3 class="font-bold text-gray-900 mb-1">QR生成</h3>
        <p class="text-xs text-gray-500">授業用コード発行</p>
      <% end %>
    </div>

    <div class="lg:col-span-3">
      <%= link_to reports_path, class: "group block bg-white rounded-[24px] p-6 shadow-sm border border-gray-100 h-full hover:border-gray-200 hover:shadow-md transition-all duration-200" do %>
        <div class="w-12 h-12 rounded-2xl bg-orange-50 text-orange-600 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
          <%= lucide_icon "bar-chart-3", class: "w-6 h-6" %>
        </div>
        <h3 class="font-bold text-gray-900 mb-1">レポート</h3>
        <p class="text-xs text-gray-500">データ分析・統計</p>
      <% end %>
    </div>

  <% else %>
    <!-- Student Actions -->
    <div class="lg:col-span-3">
      <%= link_to scan_path, class: "group block bg-white rounded-[24px] p-6 shadow-sm border border-gray-100 h-full hover:border-gray-200 hover:shadow-md transition-all duration-200" do %>
        <div class="w-12 h-12 rounded-2xl bg-gray-900 text-white flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
          <%= lucide_icon "scan-line", class: "w-6 h-6" %>
        </div>
        <h3 class="font-bold text-gray-900 mb-1">出席登録</h3>
        <p class="text-xs text-gray-500">QRコードをスキャン</p>
      <% end %>
    </div>

    <div class="lg:col-span-3">
      <%= link_to history_path, class: "group block bg-white rounded-[24px] p-6 shadow-sm border border-gray-100 h-full hover:border-gray-200 hover:shadow-md transition-all duration-200" do %>
        <div class="w-12 h-12 rounded-2xl bg-blue-50 text-blue-600 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
          <%= lucide_icon "calendar", class: "w-6 h-6" %>
        </div>
        <h3 class="font-bold text-gray-900 mb-1">出席履歴</h3>
        <p class="text-xs text-gray-500">過去の記録を確認</p>
      <% end %>
    </div>

    <div class="lg:col-span-3">
      <%= link_to attendance_requests_path, class: "group block bg-white rounded-[24px] p-6 shadow-sm border border-gray-100 h-full hover:border-gray-200 hover:shadow-md transition-all duration-200" do %>
        <div class="w-12 h-12 rounded-2xl bg-purple-50 text-purple-600 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
          <%= lucide_icon "inbox", class: "w-6 h-6" %>
        </div>
        <h3 class="font-bold text-gray-900 mb-1">出席申請</h3>
        <p class="text-xs text-gray-500">欠席・遅刻の連絡</p>
      <% end %>
    </div>

    <div class="lg:col-span-3">
      <%= link_to notifications_path, class: "group block bg-white rounded-[24px] p-6 shadow-sm border border-gray-100 h-full hover:border-gray-200 hover:shadow-md transition-all duration-200" do %>
        <div class="w-12 h-12 rounded-2xl bg-yellow-50 text-yellow-600 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
          <%= lucide_icon "bell", class: "w-6 h-6" %>
        </div>
        <h3 class="font-bold text-gray-900 mb-1">通知</h3>
        <p class="text-xs text-gray-500">お知らせ・承認結果</p>
      <% end %>
    </div>
  <% end %>

  <!-- Main Content Area -->
  <% if @user.staff? %>
    <!-- Staff Dashboard Main -->
    <div class="lg:col-span-8 space-y-6">
      <!-- Today's Attendance -->
      <div class="bg-white rounded-[24px] shadow-sm border border-gray-100 p-6">
        <div class="flex items-center justify-between mb-6">
          <h2 class="text-lg font-bold text-gray-900">本日の出席状況</h2>
          <span class="text-sm font-medium text-gray-500 bg-gray-50 px-3 py-1 rounded-full"><%= Time.zone.today.strftime("%Y/%m/%d") %></span>
        </div>

        <% if @classes.any? %>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <% @classes.each do |klass| %>
              <% stats = @today_stats[klass.id] %>
              <div class="group bg-gray-50 rounded-2xl p-4 hover:bg-gray-100 transition-colors cursor-pointer border border-transparent hover:border-gray-200">
                <div class="flex items-center justify-between mb-3">
                  <div class="font-bold text-gray-900"><%= klass.name %></div>
                  <div class="text-xs font-medium text-gray-500 bg-white px-2 py-1 rounded-md shadow-sm"><%= stats[:total] %>名</div>
                </div>
                
                <% if @today_sessions[klass.id] %>
                  <div class="mb-3">
                    <%= render "shared/session_status_badges", session: @today_sessions[klass.id] %>
                  </div>
                <% end %>

                <div class="space-y-2">
                  <div class="flex items-center justify-between text-xs font-medium text-gray-600">
                    <span>出席率</span>
                    <span><%= stats[:rate] %>%</span>
                  </div>
                  <div class="h-2 w-full bg-white rounded-full overflow-hidden">
                    <div class="h-full bg-gray-900 rounded-full" style="width: <%= stats[:rate] %>%"></div>
                  </div>
                  <div class="flex gap-2 text-[10px] text-gray-500 mt-2 overflow-x-auto no-scrollbar">
                    <span class="whitespace-nowrap flex items-center gap-1"><span class="w-1.5 h-1.5 rounded-full bg-green-500"></span>出:<%= stats[:present] %></span>
                    <span class="whitespace-nowrap flex items-center gap-1"><span class="w-1.5 h-1.5 rounded-full bg-yellow-500"></span>遅:<%= stats[:late] %></span>
                    <span class="whitespace-nowrap flex items-center gap-1"><span class="w-1.5 h-1.5 rounded-full bg-red-500"></span>欠:<%= stats[:absent] %></span>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="text-center py-8 text-gray-500 text-sm">担当クラスがありません</div>
        <% end %>
      </div>
      
      <!-- Class List -->
      <div class="bg-white rounded-[24px] shadow-sm border border-gray-100 overflow-hidden">
        <div class="p-6 border-b border-gray-100 flex items-center justify-between">
          <h2 class="text-lg font-bold text-gray-900">担当クラス一覧</h2>
        </div>
        <ul class="divide-y divide-gray-100">
          <% @classes.each do |klass| %>
            <li class="p-4 hover:bg-gray-50 transition-colors">
              <div class="flex items-center justify-between">
                <div>
                  <h3 class="font-medium text-gray-900"><%= klass.name %></h3>
                  <p class="text-xs text-gray-500 mt-0.5"><%= klass.schedule_label %> | <%= klass.room %></p>
                </div>
                <%= link_to attendance_path(class_id: klass.id), class: "inline-flex items-center justify-center w-8 h-8 rounded-full bg-white border border-gray-200 text-gray-400 hover:text-gray-900 hover:border-gray-900 transition-all" do %>
                  <%= lucide_icon "chevron-right", class: "w-4 h-4" %>
                <% end %>
              </div>
            </li>
          <% end %>
        </ul>
      </div>
    </div>

    <!-- Staff Sidebar (Alerts etc) -->
    <div class="lg:col-span-4 space-y-6">
      <!-- Alerts -->
      <div class="bg-white rounded-[24px] shadow-sm border border-gray-100 p-6 h-auto">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-base font-bold text-gray-900 flex items-center gap-2">
            <%= lucide_icon "alert-circle", class: "w-4 h-4 text-red-500" %>
            要注意学生
          </h2>
          <%= link_to "ログ", attendance_logs_path, class: "text-xs font-medium text-gray-400 hover:text-gray-900" %>
        </div>
        <% if @attention_students.any? %>
          <div class="space-y-3">
            <% @attention_students.each do |row| %>
              <div class="flex items-center justify-between p-3 rounded-xl bg-red-50 border border-red-100">
                <div class="min-w-0">
                  <p class="text-sm font-semibold text-gray-900 truncate"><%= row[:student].name %></p>
                  <p class="text-xs text-gray-500"><%= row[:student].student_id %></p>
                </div>
                <div class="text-xs font-bold text-red-600 bg-white px-2 py-1 rounded-md">
                  <%= row[:absences] %>回
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="text-center py-4">
            <p class="text-sm text-gray-400">アラートはありません</p>
          </div>
        <% end %>
      </div>

      <!-- Requests -->
      <div class="bg-white rounded-[24px] shadow-sm border border-gray-100 p-6 h-auto">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-base font-bold text-gray-900 flex items-center gap-2">
            <%= lucide_icon "inbox", class: "w-4 h-4 text-blue-500" %>
            申請待ち
          </h2>
          <%= link_to "確認", attendance_requests_path, class: "text-xs font-medium text-gray-400 hover:text-gray-900" %>
        </div>
        <% if @pending_requests.any? %>
          <div class="space-y-3">
            <% @pending_requests.each do |request| %>
              <div class="p-3 rounded-xl bg-gray-50 border border-gray-100">
                <div class="flex justify-between items-start mb-1">
                  <span class="text-xs font-bold text-gray-900"><%= request.user.name %></span>
                  <span class="text-[10px] text-gray-500"><%= request.date.strftime("%m/%d") %></span>
                </div>
                <div class="text-xs text-gray-600">
                  <%= request.school_class.name %> · 
                  <span class="font-medium <%= request.request_type == 'absent' ? 'text-red-600' : 'text-orange-600' %>">
                    <%= { "absent" => "欠席", "late" => "遅刻", "excused" => "公欠" }[request.request_type] || request.request_type %>
                  </span>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="text-center py-4">
            <p class="text-sm text-gray-400">申請待ちはありません</p>
          </div>
        <% end %>
      </div>
    </div>
  <% else %>
    <!-- Student Dashboard Main -->
    <div class="lg:col-span-8 space-y-6">
      <div class="bg-white rounded-[24px] shadow-sm border border-gray-100 p-6">
        <h2 class="text-lg font-bold text-gray-900 mb-6">出席状況 (過去30日)</h2>
        <% if @student_summary.any? %>
          <div class="space-y-6">
            <% @student_summary.each do |row| %>
              <div>
                <div class="flex items-center justify-between mb-2">
                  <span class="font-semibold text-gray-900"><%= row[:klass].name %></span>
                  <span class="font-bold text-gray-900"><%= row[:rate] %>%</span>
                </div>
                <div class="h-2.5 w-full bg-gray-100 rounded-full overflow-hidden">
                  <div class="h-full bg-gray-900 rounded-full transition-all duration-500" style="width: <%= row[:rate] %>%"></div>
                </div>
                <div class="flex gap-4 mt-2 text-xs text-gray-500">
                  <span>出席: <%= row[:present] %></span>
                  <span>遅刻: <%= row[:late] %></span>
                  <span>欠席: <%= row[:absent] %></span>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <p class="text-gray-500 text-sm">データがありません</p>
        <% end %>
      </div>
      
      <!-- Student Class List -->
      <div class="bg-white rounded-[24px] shadow-sm border border-gray-100 overflow-hidden">
        <div class="p-6 border-b border-gray-100">
          <h2 class="text-lg font-bold text-gray-900">履修クラス</h2>
        </div>
        <ul class="divide-y divide-gray-100">
          <% @classes.each do |klass| %>
            <li class="p-4 hover:bg-gray-50 transition-colors">
              <div class="flex items-center justify-between">
                <div>
                  <h3 class="font-medium text-gray-900"><%= klass.name %></h3>
                  <p class="text-xs text-gray-500 mt-0.5"><%= klass.schedule_label %> | <%= klass.room %></p>
                </div>
                <%= link_to scan_path, class: "text-xs font-bold text-white bg-gray-900 px-3 py-1.5 rounded-full hover:bg-gray-800 transition-colors" do %>
                  登録
                <% end %>
              </div>
            </li>
          <% end %>
        </ul>
      </div>
    </div>

    <!-- Student Sidebar -->
    <div class="lg:col-span-4 space-y-6">
      <!-- Warnings -->
      <div class="bg-white rounded-[24px] shadow-sm border border-gray-100 p-6">
        <h2 class="text-base font-bold text-gray-900 mb-4 flex items-center gap-2">
          <%= lucide_icon "alert-triangle", class: "w-4 h-4 text-orange-500" %>
          アラート
        </h2>
        <% if @student_warnings.any? %>
          <div class="space-y-3">
            <% @student_warnings.each do |row| %>
              <div class="p-3 bg-orange-50 rounded-xl border border-orange-100">
                <div class="font-semibold text-gray-900 text-sm"><%= row[:klass].name %></div>
                <div class="text-xs text-orange-800 mt-1">出席率が低下しています (<%= row[:rate] %>%)</div>
              </div>
            <% end %>
          </div>
        <% else %>
           <div class="text-center py-4">
            <p class="text-sm text-gray-400">現在問題はありません</p>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
</div>