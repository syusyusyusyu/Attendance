<nav class="lg:hidden fixed bottom-0 left-0 right-0 bg-white border-t border-gray-100 z-50 pb-[env(safe-area-inset-bottom)]">
  <div class="flex justify-around items-center h-16 px-2">
    <% 
      # Simplified Mobile Menu
      mobile_items = if current_user.staff?
        [
          { name: "ホーム", path: root_path, icon: "home" },
          { name: "クラス", path: school_classes_path, icon: "graduation-cap" },
          { name: "出席", path: attendance_path, icon: "check-circle-2" },
          { name: "申請", path: attendance_requests_path, icon: "inbox", badge: @pending_requests_count },
          { name: "設定", path: profile_path, icon: "user-circle" } # Using Profile as the last item for now
        ]
      else
        [
          { name: "ホーム", path: root_path, icon: "home" },
          { name: "スキャン", path: scan_path, icon: "scan-line" },
          { name: "履歴", path: history_path, icon: "calendar" },
          { name: "申請", path: attendance_requests_path, icon: "inbox", badge: @pending_requests_count },
          { name: "設定", path: profile_path, icon: "user-circle" }
        ]
      end 
    %>

    <% mobile_items.each do |item| %>
      <% 
        is_active = if item[:path] == root_path
          request.path == item[:path]
        else
          request.path == item[:path] || request.path.start_with?("#{item[:path]}/")
        end
      %>
      <%= link_to item[:path], class: "flex flex-col items-center justify-center w-full h-full relative group" do %>
        <% if is_active %>
          <span class="absolute top-0 w-8 h-1 bg-gray-900 rounded-b-full"></span>
        <% end %>
        
        <div class="relative p-1 rounded-xl transition-all duration-200 <%= is_active ? 'text-gray-900' : 'text-gray-400 group-active:scale-95' %>">
          <%= lucide_icon(item[:icon], class: "h-6 w-6") %>
          <% if item[:badge].to_i.positive? %>
            <span class="absolute top-0 right-0 flex h-2.5 w-2.5">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-400 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-red-500"></span>
            </span>
          <% end %>
        </div>
        <span class="text-[10px] font-medium mt-0.5 <%= is_active ? 'text-gray-900' : 'text-gray-400' %>">
          <%= item[:name] %>
        </span>
      <% end %>
    <% end %>
  </div>
</nav>
